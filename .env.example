# ===================================================================
# Plantilla de variables de entorno para dmn-sidecar.
# Copia este archivo a `.env` y ajusta los valores.
#   cp .env.example .env        (Linux/Mac)
#   Copy-Item .env.example .env (Windows PowerShell)
# El archivo `.env` esta en .gitignore y NO se sube a GitHub.
# docker compose lo carga automaticamente.
# ===================================================================

# --- Perfil de Spring ---
# dev = configuracion local | prod = configuracion de produccion.
SPRING_PROFILES_ACTIVE=dev

# --- Puerto HTTP del servicio ---
SERVER_PORT=8080

# --- Tuning de la JVM (consciente del contenedor) ---
# Usa hasta 75% de la RAM asignada; G1GC; muere ante OOM para que lo reinicien.
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+UseG1GC -XX:+ExitOnOutOfMemoryError

# --- Tuning del pool de hilos de Tomcat (para cargas altas) ---
TOMCAT_MAX_THREADS=200
TOMCAT_MIN_THREADS=20
TOMCAT_ACCEPT_COUNT=100
TOMCAT_MAX_CONNECTIONS=10000
